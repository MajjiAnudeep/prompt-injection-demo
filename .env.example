# =============================================================================
# Environment Variables — Prompt Injection Demo
# =============================================================================
# HOW TO USE:
#   1. Copy this file and rename the copy to: .env
#      (The .env file is gitignored and will NOT be committed to GitHub)
#   2. Fill in the values marked as REQUIRED.
#   3. Values marked as DEFAULT are pre-filled — leave them unless you have
#      a reason to change (e.g. port conflict on your machine).
#
# NEVER commit your actual .env file to GitHub.
# This .env.example file is safe to commit — it contains no real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Ports
# DEFAULT — change only if these ports are already in use on your machine.
# -----------------------------------------------------------------------------

# Port the Spring Boot backend listens on.
SERVER_PORT=8081

# Port the frontend (Nginx) is exposed on. Open http://localhost:3000 in browser.
UI_PORT=3000


# -----------------------------------------------------------------------------
# Database — PostgreSQL
# The db service in docker-compose uses these values to create the database.
# You do not need to set up PostgreSQL manually — Docker handles it.
# -----------------------------------------------------------------------------

# Name of the PostgreSQL database to create.
# DEFAULT — change if you prefer a different name.
POSTGRES_DB=prompt_injection_db

# Database username.
# DEFAULT — change if you prefer a different username.
DB_USERNAME=prompt_injection_user

# Database password.
# REQUIRED — replace with a strong password of your choice.
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD


# -----------------------------------------------------------------------------
# AI — Google Gemini
# REQUIRED — get a free API key from https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_API_KEY